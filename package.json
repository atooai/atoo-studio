{
  "name": "atoo-studio",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "atoo-studio": "bin/atoo-studio.js"
  },
  "files": [
    "bin/",
    "setup.sh",
    "dist/",
    "frontend/dist/",
    "setup-cuse.sh",
    "preload/atoo-studio-preload.c",
    "preload/atoo-studio-preload.so",
    "preload/Makefile",
    "src/serial/native/binding.gyp",
    "src/serial/native/pty_pair.c"
  ],
  "scripts": {
    "dev": "tsx --watch src/index.ts & cd frontend && npx vite build --watch & wait",
    "start": "tsx src/index.ts",
    "build:preload": "make -C preload",
    "build:serial": "cd src/serial/native && node-gyp rebuild",
    "build:backend": "npm run build:preload && npm run build:serial && tsc",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "postinstall": "[ -f src/serial/native/pty_pair.c ] && ([ \"$(uname)\" = \"Linux\" ] && make -C preload 2>/dev/null; cd src/serial/native && node-gyp rebuild 2>/dev/null) || true",
    "prepack": "cp README.md README.github.md && cp README.npm.md README.md",
    "postpack": "mv README.github.md README.md",
    "prepublishOnly": "npm run build",
    "production": "node dist/src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@simplewebauthn/server": "^13.3.0",
    "archiver": "^7.0.1",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.10.0",
    "mammoth": "^1.12.0",
    "mongodb": "^7.1.0",
    "mysql2": "^3.19.1",
    "node-forge": "^1.3.3",
    "node-pty": "^1.1.0",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.39.1",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/http-proxy": "^1.17.17",
    "@types/memjs": "^1.3.3",
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
